{
  "buildCommand": "npm run build",
  "installCommand": "npm install && cd server && npm install && cd ..",
  "devCommand": "npm run dev",
  "framework": "vite",
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3001/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://localhost:3001/uploads/:path*"
    }
  ]
}
